# Groq
GROQ_API_KEY=

# Together AI
TOGETHER_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# Mistral
MISTRAL_API_KEY=

# App Settings
DATA_DIR=./data
NODE_ENV=development
